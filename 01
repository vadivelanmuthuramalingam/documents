package com.gateway.service;

import java.net.ConnectException;
import java.net.UnknownHostException;
import java.util.concurrent.TimeoutException;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;

import com.gateway.exception.GatewayException;

import reactor.core.publisher.Mono;

@Service
public class GatewayService {

    private static final Logger log =
            LoggerFactory.getLogger(GatewayService.class);

    private final WebClientFactory factory;

    public GatewayService(WebClientFactory factory) {
        this.factory = factory;
    }

    public Mono<String> callService(String client, String payload) {

        log.info("Gateway Request Payload: {}", payload);

        return factory.getClient(client)

                .post()

                .bodyValue(payload)

                .retrieve()

                .bodyToMono(String.class)

                .doOnNext(response ->
                        log.info("Gateway Response Payload: {}", response))

                .timeout(Duration.ofSeconds(6))

                .onErrorMap(TimeoutException.class, ex -> {

                    log.error("Socket Timeout", ex);

                    return new GatewayException(
                            "SOCKET_TIMEOUT",
                            "External system timeout");
                })

                .onErrorMap(ConnectException.class, ex -> {

                    log.error("Connection Timeout", ex);

                    return new GatewayException(
                            "CONNECTION_TIMEOUT",
                            "Unable to connect to external system");
                })

                .onErrorMap(UnknownHostException.class, ex -> {

                    log.error("DNS Failure", ex);

                    return new GatewayException(
                            "DNS_ERROR",
                            "Invalid hostname");
                })

                .onErrorMap(Exception.class, ex -> {

                    log.error("Unexpected Gateway Error", ex);

                    return new GatewayException(
                            "GATEWAY_ERROR",
                            ex.getMessage());
                });
    }
}


