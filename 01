    .timeout(Duration.ofSeconds(6)) // overall timeout safeguard

    .onErrorResume(ex -> {
        if (ex instanceof java.net.ConnectException) {
            return Mono.just("Connection Timeout");
        } 
        else if (ex instanceof java.util.concurrent.TimeoutException) {
            return Mono.just("Response Timeout");
        } 
        else if (ex instanceof io.netty.handler.timeout.ReadTimeoutException) {
            return Mono.just("Socket Read Timeout");
        } 
        else if (ex instanceof io.netty.handler.timeout.WriteTimeoutException) {
            return Mono.just("Socket Write Timeout");
        } 
        else if (ex instanceof org.springframework.web.reactive.function.client.WebClientRequestException) {
            return Mono.just("Request Error: " + ex.getMessage());
        }
        else {
            return Mono.just("Unexpected Error: " + ex.getMessage());
        }
    })
    .block();
