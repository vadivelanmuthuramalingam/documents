Semaphore semaphore = new Semaphore(10);

@Bean
public Consumer<MyMessage> input() {
    return msg -> {
        try {
            semaphore.acquire();   // blocks intake
            process(msg);
        } finally {
            semaphore.release();
        }
    };
}


spring:
  cloud:
    stream:
      solace:
        bindings:
          input:
            consumer:
              useQueueNackMode: false
