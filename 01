ExchangeFilterFunction logRequest = ExchangeFilterFunction.ofRequestProcessor(request -> {
    System.out.println("➡️ REQUEST:");
    System.out.println("URI: " + request.url());
    System.out.println("Method: " + request.method());
    request.headers()
        .forEach((name, values) -> values.forEach(value -> 
            System.out.println(name + ": " + value)
        ));
    return Mono.just(request);
});

ExchangeFilterFunction logResponse = ExchangeFilterFunction.ofResponseProcessor(response -> {
    System.out.println("⬅️ RESPONSE:");
    System.out.println("Status: " + response.statusCode());

    response.headers().asHttpHeaders()
        .forEach((name, values) -> values.forEach(value -> 
            System.out.println(name + ": " + value)
        ));

    return response.bodyToMono(String.class)
        .defaultIfEmpty("")
        .flatMap(body -> {
            System.out.println("Body: " + body);

            // Rebuild response so downstream can still read body
            return Mono.just(
                ClientResponse.from(response)
                    .body(body)
                    .build()
            );
        });
});
