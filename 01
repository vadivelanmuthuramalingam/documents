import java.sql.*;
import java.util.*;

public class DynamicInsertUtil {

    public static int insert(Connection conn, String tableName, Map<String, Object> data) throws Exception {

        StringBuilder columns = new StringBuilder();
        StringBuilder placeholders = new StringBuilder();

        for (String col : data.keySet()) {

            if (columns.length() > 0) {
                columns.append(",");
                placeholders.append(",");
            }

            columns.append(col);
            placeholders.append("?");
        }

        String sql = "INSERT INTO " + tableName +
                " (" + columns + ") VALUES (" + placeholders + ")";

        System.out.println("SQL = " + sql);

        PreparedStatement ps = conn.prepareStatement(sql);

        int index = 1;

        for (Object value : data.values()) {

            setPreparedStatementValue(ps, index++, value);

        }

        return ps.executeUpdate();
    }

    private static void setPreparedStatementValue(PreparedStatement ps, int index, Object value) throws Exception {

        if (value == null) {

            ps.setNull(index, Types.NULL);

        } else if (value instanceof String) {

            ps.setString(index, (String) value);

        } else if (value instanceof Integer) {

            ps.setInt(index, (Integer) value);

        } else if (value instanceof Long) {

            ps.setLong(index, (Long) value);

        } else if (value instanceof Double) {

            ps.setDouble(index, (Double) value);

        } else if (value instanceof Float) {

            ps.setFloat(index, (Float) value);

        } else if (value instanceof Boolean) {

            ps.setBoolean(index, (Boolean) value);

        } else if (value instanceof java.sql.Date) {

            ps.setDate(index, (java.sql.Date) value);

        } else if (value instanceof java.sql.Timestamp) {

            ps.setTimestamp(index, (Timestamp) value);

        } else if (value instanceof java.util.Date) {

            ps.setTimestamp(index, new Timestamp(((java.util.Date) value).getTime()));

        } else if (value instanceof byte[]) {

            ps.setBytes(index, (byte[]) value);

        } else {

            ps.setObject(index, value);
        }
    }
}
