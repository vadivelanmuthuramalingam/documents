Convert JKS to P12

keytool -importkeystore \
  -srckeystore your-keystore.jks \
  -destkeystore your-keystore.p12 \
  -deststoretype PKCS12 \
  -srcstorepass <JKS_PASSWORD> \
  -deststorepass <P12_PASSWORD> \
  -srcalias <ALIAS>

Postman → Settings → Certificates → CA Certificates → Add

keytool -exportcert \
  -alias <ALIAS> \
  -keystore truststore.jks \
  -rfc \
  -file ca-cert.pem
