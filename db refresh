spring:
  datasource:
    url: jdbc:oracle:thin:@host:1521/service
    username: appuser
    password: password

    hikari:
      maximum-pool-size: 20
      minimum-idle: 5

      validation-timeout: 5000
      connection-timeout: 10000

      max-lifetime: 1800000
      idle-timeout: 600000

      keepalive-time: 30000

      connection-test-query: SELECT 1 FROM DUAL

management:
  endpoint:
    health:
      show-details: always

  health:
    db:
      enabled: true



